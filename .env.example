# ── Postgres (individual vars — used by db_conn.py and docker-compose) ────────
# When running with Docker Compose, POSTGRES_SERVER must be the service name: db:5432
# When running locally, POSTGRES_SERVER is: localhost:5432
POSTGRES_USER=ong_user
POSTGRES_PASSWORD=ong_password
POSTGRES_SERVER=db:5432
POSTGRES_DB=ong_solidaria

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
FRONTEND_URL=http://localhost:5173
