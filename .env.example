# ── MySQL (individual vars — used by db_conn.py and docker-compose) ───────────
# When running with Docker Compose, MYSQL_SERVER must be the service name: db:3306
# When running locally (XAMPP), MYSQL_SERVER is: localhost:3306
MYSQL_USER=ong_user
MYSQL_PASSWORD=ong_password
MYSQL_SERVER=db:3306
MYSQL_DATABASE=ong_solidaria

# ── MySQL container root password (docker-compose only) ───────────────────────
MYSQL_ROOT_PASSWORD=root_secret

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
FRONTEND_URL=http://localhost:5173
